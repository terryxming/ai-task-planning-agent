{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-task-planning-agent/execution-manifest.schema.json",
  "title": "Task Execution Manifest",
  "type": "object",
  "required": [
    "task_goal",
    "non_goals",
    "input_contract",
    "output_contract",
    "context_contracts",
    "workflow_steps",
    "sandbox_rules",
    "acceptance_criteria",
    "failure_criteria",
    "trace_requirements",
    "recovery_paths",
    "regression_cases"
  ],
  "properties": {
    "task_goal": {
      "type": "string",
      "minLength": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_contract": {
      "type": "object"
    },
    "output_contract": {
      "type": "object"
    },
    "context_contracts": {
      "type": "array"
    },
    "workflow_steps": {
      "type": "array"
    },
    "sandbox_rules": {
      "type": "array"
    },
    "acceptance_criteria": {
      "type": "array"
    },
    "failure_criteria": {
      "type": "array"
    },
    "trace_requirements": {
      "type": "array",
      "minItems": 1
    },
    "recovery_paths": {
      "type": "array",
      "minItems": 1
    },
    "regression_cases": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
